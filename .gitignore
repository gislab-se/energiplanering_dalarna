# OS/editor
.DS_Store
Thumbs.db
*.tmp
*.bak
*.swp
.vscode/
.idea/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/

# R
.Rhistory
.RData
.Rproj.user/

# QGIS temp/backups
*.qgs~
*.qgz~
*.gpkg-wal
*.gpkg-shm

# Local runtime
logs/*.log

# Local-only project data
data/raw/**
data/external/**
data/processed/**
!data/**/.gitkeep

# Interim policy:
# - keep all interim data ignored by default
# - allow the small app-ready Streamlit bundle
# - keep novus/private interim data ignored
data/interim/*
!data/interim/.gitkeep
!data/interim/hem_kommun_network/
!data/interim/hem_kommun_network/**
data/interim/novus/
data/interim/novus/**

# Local-only documents and exports
docs/inputs/**
docs/slides/**
maps/exports/**
!docs/**/.gitkeep
!maps/**/.gitkeep
