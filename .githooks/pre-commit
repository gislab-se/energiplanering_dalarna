#!/bin/sh

# Block committing local-only data and heavy binary assets.
if git diff --cached --name-only --diff-filter=ACMRT | grep -E '^(data_raw/|data/raw/|data/external/|data/interim/|data/processed/|docs/inputs/|docs/slides/|maps/exports/)|\.(zip|7z|rar|gpkg|shp|dbf|shx|prj|cpg|tif|tiff|pdf|ppt|pptx)$' >/dev/null 2>&1; then
  echo "ERROR: Commit blocked by data-protection hook."
  echo "Staged files include local-only data/docs/exports or blocked binary types."
  echo "Unstage with: git restore --staged <file>"
  exit 1
fi

exit 0
